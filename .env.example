# ─── Ma'aash Environment Variables ───────────────────────
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# Email (SMTP) — used to receive form submissions
# Works with Gmail, Zoho, Outlook, SendGrid SMTP, etc.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-app-password       # Gmail: use an App Password, not your account password
EMAIL_TO=your@gmail.com            # Where submissions are delivered

# Optional: Vercel / deployment URL (used for OG meta tags etc.)
NEXT_PUBLIC_SITE_URL=https://maaash.com
